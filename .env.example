# Server Configuration
SERVER_LOG_LEVEL=info

# RabbitMQ Configuration
MQTT_BROKER_URL=amqp://admin:password@rabbitmq:5672/
MQTT_EXCHANGE=amq.topic
MQTT_QUEUE=transformer_device_queue
MQTT_ROUTING_KEY=device.data
MQTT_OUTPUT_TOPIC=transformed/device/location
MQTT_CONSUMER_TAG=transformer-service
MQTT_PREFETCH_COUNT=10
MQTT_AUTO_ACK=false

# Raw Data Logging Configuration
RAW_DATA_LOG_DIR=logs/raw_data
RAW_DATA_ENABLE_FILE_LOG=true
RAW_DATA_ENABLE_JSON_LOG=true
RAW_DATA_MAX_FILE_SIZE=104857600